# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Anthropic — server-side only, never exposed to client
ANTHROPIC_API_KEY=your_anthropic_api_key

# VinAudit — optional, enables accident/ownership history in VIN Lookup
# Get your key at vinaudit.com (~$0.50/lookup). Leave blank to use free NHTSA data only.
VINAUDIT_API_KEY=
